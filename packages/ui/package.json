    "./src/*": "./src/*"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "test": "jest",
    "test:visual": "jest --selectProjects visual",
    "test:unit": "jest --selectProjects unit",
    "typecheck": "tsc",
    "lint": "eslint \"src/**/*.{js,ts,tsx}\"",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/txbrown/react-native-circuit-ui.git"
  },
  "author": "txbrown <ricardo@yonkolevel.com> (https://github.com/txbrown)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/txbrown/react-native-circuit-ui/issues"
  },
  "homepage": "https://github.com/txbrown/react-native-circuit-ui#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@circuit-ui/tokens": "workspace:*",
    "lucide-react-native": "^0.481.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^17.0.2",
    "@evilmartians/lefthook": "^1.5.0",
    "@react-native-community/slider": "^4.5.5",
    "@react-native/eslint-config": "^0.73.1",
    "@release-it/conventional-changelog": "^9.0.2",
    "@shopify/react-native-skia": "^2.5.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.5",
    "@types/jest-image-snapshot": "^6.4.1",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.2.44",
    "@types/react-test-renderer": "^18.3.1",
    "commitlint": "^17.0.2",
    "conventional-changelog-angular": "^8.0.0",
    "del-cli": "^5.1.0",
    "eslint": "^8.51.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "jest-image-snapshot": "^6.5.2",
    "pixelmatch": "5.3.0",
    "prettier": "^3.0.3",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "react-native-builder-bob": "^0.37.0",
    "react-native-gesture-handler": "^2.20.2",
    "react-native-reanimated": "^3.17.4",
    "react-native-svg": "^15.11.2",
    "react-native-worklets": "0.8.3",
    "react-test-renderer": "18.3.1",
    "release-it": "^17.10.0",
    "typescript": "^5.2.2"
  },
  "resolutions": {
    "@types/react": "^18.2.44"
  },
  "peerDependencies": {
    "@react-native-community/slider": ">=4.0.0",
    "@shopify/react-native-skia": ">=2.0.0",
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-svg": ">=15.0.0",
    "react-native-worklets": ">=0.8.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json",
          "esm": true
        }
      ]
    ]
  },
  "create-react-native-library": {
    "languages": "js",
    "type": "library",
    "version": "0.48.3"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        },
        "infile": "CHANGELOG.md"
      }
    }
  }
}
