{
  "name": "@circuit-ui/core",
  "version": "0.3.2",
  "description": "UI Kit for building React Native apps at Yonko Level",
  "source": "./src/index.tsx",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./Avatar": {
      "source": "./src/components/Avatar/index.ts",
      "import": "./lib/module/components/Avatar/index.js",
      "require": "./lib/commonjs/components/Avatar/index.js"
    },
    "./Banner": {
