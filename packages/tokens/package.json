{
  "name": "@circuit-ui/tokens",
  "version": "0.1.0",
  "description": "Design tokens for the Midicircuit design system — framework-agnostic",
  "source": "./src/index.ts",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/module/src/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    }
  },
  "files": [
    "src",
    "lib",
    "!lib/**/__tests__",
    "!**/.*"
  ],
  "scripts": {
    "prepare": "bob build",
    "typecheck": "tsc",
    "clean": "del-cli lib"
  },
  "devDependencies": {
    "del-cli": "^5.1.0",
    "react-native-builder-bob": "^0.37.0",
    "typescript": "^5.2.2"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json",
          "esm": true
        }
      ]
    ]
  }
}
